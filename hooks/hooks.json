{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/setup/setup.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "VENV_PY=$([ -x \"$CLAUDE_PLUGIN_ROOT/.venv/Scripts/python\" ] && echo \"$CLAUDE_PLUGIN_ROOT/.venv/Scripts/python\" || echo \"$CLAUDE_PLUGIN_ROOT/.venv/bin/python\"); \"$VENV_PY\" \"$CLAUDE_PLUGIN_ROOT/hooks/preflight_check.py\"",
            "timeout": 8,
            "statusMessage": "LOCI preflight..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "VENV_PY=$([ -x \"$CLAUDE_PLUGIN_ROOT/.venv/Scripts/python\" ] && echo \"$CLAUDE_PLUGIN_ROOT/.venv/Scripts/python\" || echo \"$CLAUDE_PLUGIN_ROOT/.venv/bin/python\"); \"$VENV_PY\" \"$CLAUDE_PLUGIN_ROOT/hooks/post_edit_nudge.py\"",
            "timeout": 5,
            "statusMessage": "LOCI post-edit check..."
          }
        ]
      }
    ]
  }
}