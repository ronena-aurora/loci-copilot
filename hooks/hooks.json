{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-init.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "VENV_PY=$([ -x \"$CLAUDE_PLUGIN_ROOT/.venv/Scripts/python\" ] && echo \"$CLAUDE_PLUGIN_ROOT/.venv/Scripts/python\" || echo \"$CLAUDE_PLUGIN_ROOT/.venv/bin/python\"); [ -x \"$VENV_PY\" ] && \"$VENV_PY\" \"$CLAUDE_PLUGIN_ROOT/hooks/preflight_check.py\" || true",
            "timeout": 8,
            "statusMessage": "LOCI — execution-aware analysis..."
          }
        ]
      }
    ],
    "PostToolUse": [
    ]
  }
}
